# Використовуємо офіційний образ Node.js
FROM node:18

# Створюємо робочу директорію всередині контейнера
WORKDIR /app

# Копіюємо файли конфігурації
COPY package*.json ./

# залежності
RUN npm install

# Копіюємо весь інший код
COPY . .

# Відкриваємо порт)
EXPOSE 3000

# Команда для запуску
CMD ["node", "index.js", "-h", "0.0.0.0", "-p", "3000", "-c", "./my_cache"]